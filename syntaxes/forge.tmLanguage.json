{
  "scopeName": "forge.inject",
  "injectionSelector": "L:source.js, L:source.ts, L:source.jsx, L:source.tsx",
  "patterns": [{ "include": "#code-property-string" }],
  "repository": {
    "code-property-string": {
      "begin": "\\bcode\\b\\s*:\\s*([\"`])",
      "beginCaptures": {
        "0": { "name": "meta.forge.code.begin" }
      },
      "end": "(?<!\\\\)\\1",
      "endCaptures": {
        "0": { "name": "meta.forge.code.end" }
      },
      "patterns": [{ "include": "#forge-function-call" }]
    },

    "forge-function-call": {
      "patterns": [
        {
          "name": "meta.function-call.forge",
          "begin": "(\\$)(!?)(#?)(?:(@)\\[([^\\]\\n]?)\\])?([a-zA-Z_]+)(\\[)",
          "beginCaptures": {
            "1": { "name": "forge.function.dollar" },
            "2": { "name": "forge.operator.negation" },
            "3": { "name": "forge.operator.silent" },
            "4": { "name": "forge.operator.count" },
            "5": { "name": "forge.operator.count.delimiter" },
            "7": { "name": "forge.function.bracket.open" }
          },
          "end": "(\\])",
          "endCaptures": {
            "1": { "name": "forge.function.bracket.close" }
          },
          "patterns": [
            { "include": "#forge-function-call" },
            { "name": "forge.function.semicolon", "match": ";" }
          ]
        },
        {
          "name": "meta.function-prefix.forge",
          "match": "(\\$)(!?)(#?)(?:(@)\\[([^\\]\\n]?)\\])?([a-zA-Z_]+)",
          "captures": {
            "1": { "name": "forge.function.dollar" },
            "2": { "name": "forge.operator.negation" },
            "3": { "name": "forge.operator.silent" },
            "4": { "name": "forge.operator.count" },
            "5": { "name": "forge.operator.count.delimiter" }
          }
        }
      ]
    }
  }
}
