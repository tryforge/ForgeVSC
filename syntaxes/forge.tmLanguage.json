{
  "scopeName": "forge.inject",
  "injectionSelector": "L:source.js -comment, L:source.ts -comment, L:source.jsx -comment, L:source.tsx -comment",
  "patterns": [{ "include": "#code-property-string" }],
  "repository": {
    "code-property-string": {
      "begin": "\\bcode\\b\\s*:\\s*([\"`'])",
      "beginCaptures": {
        "0": { "name": "meta.forge.code.begin" }
      },
      "end": "(?<!\\\\)\\1",
      "endCaptures": {
        "0": { "name": "meta.forge.code.end" }
      },
      "patterns": [{ "include": "#djs-eval" }, { "include": "#forge-brackets" }]
    },

    "djs-eval": {
      "name": "meta.function.djsEval.forge",
      "begin": "(?<!\\\\)\\$(?:!?#?(?:@\\[[^\\]\\n]?\\])?)?(?i:(djsEval|js))\\[",
      "beginCaptures": {
        "0": { "name": "entity.name.function.forge" }
      },
      "end": "\\]",
      "endCaptures": {
        "0": { "name": "punctuation.section.brackets.end.forge" }
      },
      "contentName": "source.js",
      "patterns": [{ "include": "source.js" }]
    },

    "forge-brackets": {
      "patterns": [
        {
          "name": "meta.function-call.forge",
          "begin": "(?<!\\\\)(?:\\$!?#?(?:@\\[[^\\]\\n]?\\])?)?[a-zA-Z0-9]+(\\[)",
          "beginCaptures": {
            "1": { "name": "forge.function.bracket.open" }
          },
          "end": "(\\])",
          "endCaptures": {
            "1": { "name": "forge.function.bracket.close" }
          },
          "patterns": [
            { "include": "#djs-eval" },
            { "include": "#forge-brackets" }
          ]
        }
      ]
    }
  }
}
