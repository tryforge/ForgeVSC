{
  "name": "forgevsc",
  "displayName": "ForgeVSC",
  "description": "Official Visual Studio Code Extension for ForgeScript.",
  "publisher": "tryforge",
  "version": "1.2.0",
  "icon": "./assets/ForgeScript.png",
  "main": "./out/extension.js",
  "browser": "./out/web/extension.js",
  "author": {
    "name": "xNickyDev"
  },
  "engines": {
    "vscode": "^1.116.0"
  },
  "categories": [
    "Programming Languages",
    "Visualization",
    "Other"
  ],
  "extensionKind": [
    "workspace"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tryforge/ForgeVSC.git"
  },
  "license": "LGPL-3.0-or-later",
  "activationEvents": [
    "onLanguage:javascript",
    "onLanguage:typescript",
    "onLanguage:javascriptreact",
    "onLanguage:typescriptreact",
    "workspaceContains:.forgevsc.json",
    "workspaceContains:.vscode/.forgevsc.json"
  ],
  "contributes": {
    "languages": [
      {
        "id": "forge",
        "aliases": [
          "Forge",
          "ForgeScript",
          "forgescript"
        ],
        "extensions": [
          ".fs"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "dark": "./assets/ForgeScript.png",
          "light": "./assets/ForgeScript.png"
        }
      }
    ],
    "commands": [
      {
        "command": "forgevsc.createConfig",
        "title": "Create config file (.forgevsc.json)",
        "category": "ForgeVSC"
      },
      {
        "command": "forgevsc.reloadFunctionMetadata",
        "title": "Fetch function metadata. Use with caution!",
        "category": "ForgeVSC",
        "icon": "$(refresh)"
      },
      {
        "command": "forgevsc.searchGuides",
        "title": "Search Guides",
        "category": "ForgeVSC",
        "icon": "$(search)"
      },
      {
        "command": "forgevsc.reloadGuideMetadata",
        "title": "Refresh Guides",
        "category": "ForgeVSC",
        "icon": "$(refresh)"
      },
      {
        "command": "forgevsc.openGuide",
        "title": "Open Guide",
        "category": "ForgeVSC"
      },
      {
        "command": "forgevsc.previewGuide",
        "title": "Preview Guide",
        "category": "ForgeVSC"
      },
      {
        "command": "forgevsc.favoriteGuide",
        "title": "Add to Favorites",
        "category": "ForgeVSC",
        "icon": "$(star-empty)"
      },
      {
        "command": "forgevsc.unfavoriteGuide",
        "title": "Remove from Favorites",
        "category": "ForgeVSC",
        "icon": "$(star-full)"
      },
      {
        "command": "forgevsc.createGuide",
        "title": "Create Guide",
        "category": "ForgeVSC",
        "icon": "$(add)"
      },
      {
        "command": "forgevsc.openGuideExternal",
        "title": "Open Guide",
        "category": "ForgeVSC",
        "icon": "$(link-external)"
      },
      {
        "command": "forgevsc.openExtensionSettings",
        "title": "Open Extension Settings",
        "category": "ForgeVSC",
        "icon": "$(settings)"
      }
    ],
    "grammars": [
      {
        "scopeName": "forge.inject",
        "path": "./syntaxes/forge.tmLanguage.json",
        "injectTo": [
          "source.js",
          "source.ts",
          "source.jsx",
          "source.tsx"
        ]
      }
    ],
    "jsonValidation": [
      {
        "fileMatch": [
          ".forgevsc.json",
          ".vscode/.forgevsc.json"
        ],
        "url": "./forgevsc.schema.json"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "forge",
          "title": "Guides",
          "icon": "$(book)"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "forge.guidesView",
        "contents": "No guides available.\n[$(refresh) Reload Guides](command:forgevsc.reloadGuideMetadata)\n[$(add) Create Guide](command:forgevsc.createGuide)"
      }
    ],
    "views": {
      "forge": [
        {
          "id": "forge.guidesView",
          "name": "Guides",
          "icon": "$(book)"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "forgevsc.createGuide",
          "when": "view == forge.guidesView",
          "group": "navigation@0"
        },
        {
          "command": "forgevsc.searchGuides",
          "when": "view == forge.guidesView",
          "group": "navigation@1"
        },
        {
          "command": "forgevsc.reloadGuideMetadata",
          "when": "view == forge.guidesView",
          "group": "navigation@2"
        }
      ],
      "view/item/context": [
        {
          "command": "forgevsc.favoriteGuide",
          "when": "view == forge.guidesView && viewItem == guide",
          "group": "inline"
        },
        {
          "command": "forgevsc.unfavoriteGuide",
          "when": "view == forge.guidesView && viewItem == guide.favorite",
          "group": "inline"
        },
        {
          "command": "forgevsc.openGuideExternal",
          "when": "view == forge.guidesView && viewItem == guide || view == forge.guidesView && viewItem == guide.favorite",
          "group": "inline@2"
        }
      ],
      "commandPalette": [
        {
          "command": "forgevsc.openGuide",
          "when": "false"
        },
        {
          "command": "forgevsc.previewGuide",
          "when": "false"
        },
        {
          "command": "forgevsc.favoriteGuide",
          "when": "false"
        },
        {
          "command": "forgevsc.unfavoriteGuide",
          "when": "false"
        },
        {
          "command": "forgevsc.openGuideExternal",
          "when": "false"
        }
      ]
    },
    "configurationDefaults": {
      "editor.quickSuggestions": {
        "other": true,
        "comments": false,
        "strings": true
      },
      "editor.suggestOnTriggerCharacters": true,
      "editor.tokenColorCustomizations": {
        "textMateRules": [
          {
            "scope": "forge.function.bracket.open",
            "settings": {
              "foreground": "#ffd700"
            }
          },
          {
            "scope": "forge.function.bracket.close",
            "settings": {
              "foreground": "#ffd700"
            }
          }
        ]
      }
    },
    "configuration": {
      "title": "ForgeVSC",
      "properties": {
        "forgevsc.global.enabledWorkspaces": {
          "order": 0,
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "uniqueItems": true,
          "scope": "machine",
          "description": "List of workspace names where ForgeVSC is enabled. Leave empty to enable the extension for all workspaces."
        },
        "forgevsc.workspace.additionalPackages": {
          "order": 1,
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true,
          "description": "Additional packages/extensions to fetch metadata from. By default, installed Forge packages are detected automatically. This property is only needed if metadata fetching fails or you want to include extra packages."
        },
        "forgevsc.workspace.customFunctionPaths": {
          "order": 2,
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "uniqueItems": true,
          "description": "Path(s) to your custom functions folder(s). This is used to generate metadata and to provide full extension feature support for your custom functions."
        },
        "forgevsc.workspace.colors.function.name": {
          "order": 10,
          "type": "string",
          "default": "#ac75ff",
          "description": "The highlight color used for function names."
        },
        "forgevsc.workspace.colors.function.dollar": {
          "order": 11,
          "type": "string",
          "default": "#fe7ceb",
          "description": "The highlight color used for function dollar signs ($)."
        },
        "forgevsc.workspace.colors.function.semicolon": {
          "order": 12,
          "type": "string",
          "default": "#c586c0",
          "description": "The highlight color used for function semicolons (;)."
        },
        "forgevsc.workspace.colors.operators.negation": {
          "order": 13,
          "type": "string",
          "default": "#4FA3FF",
          "description": "The highlight color used for the negation operator (!)."
        },
        "forgevsc.workspace.colors.operators.silent": {
          "order": 14,
          "type": "string",
          "default": "#FF9F43",
          "description": "The highlight color used for the silent operator (#)."
        },
        "forgevsc.workspace.colors.operators.count": {
          "order": 15,
          "type": "string",
          "default": "#33D17A",
          "description": "The highlight color used for the count operator (@[x])."
        },
        "forgevsc.workspace.colors.operators.countDelimiter": {
          "order": 16,
          "type": "string",
          "default": "#76E3A0",
          "description": "The highlight color used for the count operator delimiter (separator)."
        },
        "forgevsc.workspace.features.folding": {
          "order": 30,
          "type": "boolean",
          "default": true,
          "description": "Whether folding for multi-line function contents should be enabled."
        },
        "forgevsc.workspace.features.hoverInfo": {
          "order": 31,
          "type": "boolean",
          "default": true,
          "description": "Whether hover info cards for functions and operators should be enabled."
        },
        "forgevsc.workspace.features.suggestions": {
          "order": 32,
          "type": "boolean",
          "default": true,
          "description": "Whether suggestions for bracket placement should be enabled."
        },
        "forgevsc.workspace.features.signatureHelp": {
          "order": 33,
          "type": "boolean",
          "default": true,
          "description": "Whether signature help for function arguments should be enabled."
        },
        "forgevsc.workspace.features.diagnostics": {
          "order": 34,
          "type": "boolean",
          "default": true,
          "description": "Whether diagnostics for function validation should be enabled."
        },
        "forgevsc.workspace.features.autocompletion": {
          "order": 35,
          "type": "boolean",
          "default": true,
          "description": "Whether autocompletion for functions and arguments should be enabled."
        }
      }
    }
  },
  "scripts": {
    "web": "npx vscode-test-web --extensionDevelopmentPath=. --port=3001",
    "publish": "dotenv -- sh -c 'npm run package && npx ovsx publish -p $OVSX_PAT'",
    "package": "npx @vscode/vsce package",
    "vscode:prepublish": "npm run build",
    "compile": "tsc -p ./",
    "build:web": "node scripts/esbuild.mjs",
    "build": "npm run compile && npm run build:web",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run build && npm run lint",
    "lint": "eslint src"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.6.0",
    "@types/vscode": "^1.116.0",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "@vscode/test-web": "^0.0.80",
    "@vscode/vsce": "^3.9.0",
    "dotenv-cli": "^11.0.0",
    "esbuild": "^0.28.0",
    "eslint": "^10.2.0",
    "ovsx": "^0.10.11"
  },
  "dependencies": {
    "typescript": "^6.0.2"
  }
}
