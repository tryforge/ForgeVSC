{
  "name": "forge.vsc",
  "displayName": "ForgeVSC",
  "description": "Official Visual Studio Code Extension for ForgeScript.",
  "publisher": "tryforge",
  "version": "1.0.0",
  "icon": "./assets/ForgeScript.png",
  "main": "./out/extension.js",
  "engines": {
    "vscode": "^1.96.0"
  },
  "categories": [
    "Programming Languages",
    "Visualization",
    "Other"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tryforge/ForgeVSC.git"
  },
  "activationEvents": [
    "workspaceContains:.forgevsc.json",
    "workspaceContains:.vscode/.forgevsc.json",
    "onLanguage:javascript",
    "onLanguage:typescript",
    "onLanguage:javascriptreact",
    "onLanguage:typescriptreact"
  ],
  "contributes": {
    "languages": [
      {
        "id": "forge",
        "aliases": [
          "Forge",
          "ForgeScript",
          "forgescript"
        ],
        "extensions": [
          ".fs"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "dark": "./assets/ForgeScript.png",
          "light": "./assets/ForgeScript.png"
        }
      }
    ],
    "commands": [
      {
        "command": "forgevsc.createConfig",
        "title": "Create config file (.forgevsc.json)",
        "category": "ForgeVSC"
      },
      {
        "command": "forgevsc.reloadMetadata",
        "title": "Fetch function metadata. Use with caution!",
        "category": "ForgeVSC"
      }
    ],
    "grammars": [
      {
        "scopeName": "forge.inject",
        "path": "./syntaxes/forge.tmLanguage.json",
        "injectTo": [
          "source.js",
          "source.ts",
          "source.jsx",
          "source.tsx"
        ]
      }
    ],
    "configurationDefaults": {
      "editor.quickSuggestions": {
        "other": true,
        "comments": false,
        "strings": true
      },
      "editor.suggestOnTriggerCharacters": true,
      "editor.semanticHighlighting.enabled": true,
      "editor.tokenColorCustomizations": {
        "textMateRules": [
          {
            "scope": "forge.function.bracket.open",
            "settings": {
              "foreground": "#ffd700"
            }
          },
          {
            "scope": "forge.function.bracket.close",
            "settings": {
              "foreground": "#ffd700"
            }
          },
          {
            "scope": "forge.function.semicolon",
            "settings": {
              "foreground": "#c586c0"
            }
          },
          {
            "scope": "forge.function.dollar",
            "settings": {
              "foreground": "#fe7ceb"
            }
          }
        ]
      },
      "editor.semanticTokenColorCustomizations": {
        "rules": {
          "function": "#ac75ff"
        }
      }
    },
    "jsonValidation": [
      {
        "fileMatch": [
          ".forgevsc.json",
          ".vscode/.forgevsc.json"
        ],
        "url": "./forgevsc.schema.json"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src"
  },
  "devDependencies": {
    "@tryforge/forgescript": "^2.6.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "20.x",
    "@types/vscode": "^1.96.0",
    "@typescript-eslint/eslint-plugin": "^8.17.0",
    "@typescript-eslint/parser": "^8.17.0",
    "eslint": "^9.16.0",
    "typescript": "^5.7.2"
  }
}
