{
  "name": "forge.vsc",
  "displayName": "ForgeVSC",
  "description": "Official Visual Studio Code Extension for ForgeScript.",
  "publisher": "tryforge",
  "version": "0.0.1",
  "icon": "./assets/ForgeScript.png",
  "main": "./out/extension.js",
  "engines": {
    "vscode": "^1.96.0"
  },
  "categories": [
    "Programming Languages",
    "Visualization",
    "Other"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tryforge/ForgeVSC.git"
  },
  "activationEvents": [
    "onLanguage:javascript"
  ],
  "contributes": {
    "languages": [
      {
        "id": "forge",
        "aliases": [
          "Forge",
          "ForgeScript",
          "forgescript"
        ],
        "extensions": [
          ".fs"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "dark": "./assets/ForgeScript.png",
          "light": "./assets/ForgeScript.png"
        }
      }
    ],
    "grammars": [
      {
        "scopeName": "forgescript.template",
        "path": "./syntaxes/forge.tmLanguage.json",
        "injectTo": [
          "source.js",
          "source.ts"
        ]
      }
    ],
    "configurationDefaults": {
      "[javascript]": {
        "editor.quickSuggestions": {
          "other": true,
          "comments": false,
          "strings": true
        },
        "editor.suggestOnTriggerCharacters": true
      }
    },
    "configuration": {
      "type": "object",
      "title": "Autocomplete",
      "properties": {
        "Autocomplete.functionsURL": {
          "type": "string",
          "default": "https://raw.githubusercontent.com/tryforge/ForgeScript/main/metadata/functions.json"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@tryforge/forgescript": "^2.6.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "20.x",
    "@types/vscode": "^1.96.0",
    "@typescript-eslint/eslint-plugin": "^8.17.0",
    "@typescript-eslint/parser": "^8.17.0",
    "@vscode/test-cli": "^0.0.10",
    "@vscode/test-electron": "^2.4.1",
    "eslint": "^9.16.0",
    "typescript": "^5.7.2"
  }
}
